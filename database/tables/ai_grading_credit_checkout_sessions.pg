columns
    agent_user_id: bigint not null
    amount_milli_dollars: bigint not null
    completed_at: timestamp with time zone
    course_instance_id: bigint not null
    created_at: timestamp with time zone not null default now()
    credits_added: boolean not null default false
    data: jsonb not null
    id: bigint not null default nextval('ai_grading_credit_checkout_sessions_id_seq'::regclass)
    refunded_at: timestamp with time zone
    stripe_object_id: text not null

indexes
    ai_grading_credit_checkout_sessions_pkey: PRIMARY KEY (id) USING btree (id)
    ai_grading_credit_checkout_sessions_stripe_object_id_key: UNIQUE (stripe_object_id) USING btree (stripe_object_id)
    ai_grading_credit_checkout_sessions_agent_user_id_idx: USING btree (agent_user_id)
    ai_grading_credit_checkout_sessions_course_instance_id_idx: USING btree (course_instance_id)

check constraints
    ai_grading_credit_checkout_sessions_amount_milli_dollars_check: CHECK (amount_milli_dollars > 0)

foreign-key constraints
    ai_grading_credit_checkout_sessions_agent_user_id_fkey: FOREIGN KEY (agent_user_id) REFERENCES users(id) ON UPDATE CASCADE ON DELETE CASCADE
    ai_grading_credit_checkout_sessions_course_instance_id_fkey: FOREIGN KEY (course_instance_id) REFERENCES course_instances(id) ON UPDATE CASCADE ON DELETE CASCADE

referenced by
    ai_grading_credit_pool_changes: FOREIGN KEY (checkout_session_id) REFERENCES ai_grading_credit_checkout_sessions(id) ON UPDATE CASCADE ON DELETE SET NULL
