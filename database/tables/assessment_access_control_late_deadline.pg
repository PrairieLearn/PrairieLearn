columns
    assessment_access_control_id: bigint not null
    credit: integer not null
    date: timestamp with time zone not null
    id: bigint not null default nextval('assessment_access_control_late_deadline_id_seq'::regclass)
    sort_order: integer not null

indexes
    assessment_access_control_late_deadline_pkey: PRIMARY KEY (id) USING btree (id)
    assessment_access_control_late_deadline_access_control_id_idx: USING btree (assessment_access_control_id)

foreign-key constraints
    assessment_access_control_late_deadline_access_control_id_fkey: FOREIGN KEY (assessment_access_control_id) REFERENCES assessment_access_control(id) ON UPDATE CASCADE ON DELETE CASCADE
