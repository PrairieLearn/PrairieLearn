columns
    assessment_access_control_id: bigint not null
    id: bigint not null default nextval('assessment_access_control_prairietest_exam_id_seq'::regclass)
    read_only: boolean
    uuid: uuid not null

indexes
    assessment_access_control_prairietest_exam_pkey: PRIMARY KEY (id) USING btree (id)
    assessment_access_control_prairietest_exam_aac_id_idx: USING btree (assessment_access_control_id)

foreign-key constraints
    assessment_access_control_prairietest_ex_access_control_id_fkey: FOREIGN KEY (assessment_access_control_id) REFERENCES assessment_access_control(id) ON UPDATE CASCADE ON DELETE CASCADE
