columns
    assessment_access_control_rule_id: bigint not null
    credit: integer not null
    date: timestamp with time zone not null
    id: bigint not null default nextval('assessment_access_control_late_deadlines_id_seq'::regclass)

indexes
    assessment_access_control_late_deadlines_pkey: PRIMARY KEY (id) USING btree (id)
    aac_late_deadlines_rule_id_date_unique: UNIQUE (assessment_access_control_rule_id, date) USING btree (assessment_access_control_rule_id, date)
    aac_late_deadlines_rule_id_idx: USING btree (assessment_access_control_rule_id)

check constraints
    assessment_access_control_late_deadlines_credit_check: CHECK (credit >= 0)

foreign-key constraints
    aac_late_deadlines_rule_id_fkey: FOREIGN KEY (assessment_access_control_rule_id) REFERENCES assessment_access_control_rules(id) ON UPDATE CASCADE ON DELETE CASCADE
