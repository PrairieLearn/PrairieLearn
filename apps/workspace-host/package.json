{
  "name": "@prairielearn/workspace-host",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsgo && tscp",
    "dev": "tsx watch --clear-screen=false --include \"**/*.sql\" --include \"**/*.json\" src/interface.js",
    "dev:no-watch": "tsx src/interface.js",
    "start": "node dist/interface.js",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-ecr": "^3.1076.0",
    "@aws-sdk/client-s3": "^3.1076.0",
    "@aws-sdk/credential-providers": "^3.1076.0",
    "@aws-sdk/lib-storage": "^3.1076.0",
    "@prairielearn/aws": "workspace:^",
    "@prairielearn/cache": "workspace:^",
    "@prairielearn/config": "workspace:^",
    "@prairielearn/docker-utils": "workspace:^",
    "@prairielearn/logger": "workspace:^",
    "@prairielearn/postgres": "workspace:^",
    "@prairielearn/run": "workspace:^",
    "@prairielearn/sentry": "workspace:^",
    "@prairielearn/workspace-utils": "workspace:^",
    "@socket.io/redis-emitter": "^5.1.0",
    "archiver": "^8.0.0",
    "async": "^3.2.6",
    "async-mutex": "^0.5.0",
    "body-parser": "^1.20.5",
    "debug": "^4.4.3",
    "dockerode": "^5.0.1",
    "express": "^4.22.2",
    "express-async-handler": "^1.2.0",
    "ioredis": "^5.11.1",
    "minimist": "^1.2.8",
    "shlex": "^3.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@prairielearn/tsconfig": "workspace:^",
    "@types/archiver": "^8.0.0",
    "@types/async": "^3.2.25",
    "@types/body-parser": "^1.19.6",
    "@types/debug": "^4.1.13",
    "@types/dockerode": "^4.0.1",
    "@types/express": "^4.17.25",
    "@types/minimist": "^1.2.5",
    "@types/node": "^24.13.2",
    "@typescript/native-preview": "beta",
    "@vitest/coverage-v8": "^4.1.9",
    "fast-glob": "^3.3.3",
    "tsx": "^4.22.4",
    "typescript-cp": "^0.1.9",
    "vitest": "^4.1.9"
  }
}
