{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "allow-blank": {
      "type": "string",
      "format": "boolean"
    },
    "answers-name": {
      "type": "string"
    },
    "code-language": {
      "type": "string"
    },
    "display-blocks": {
      "type": "string",
      "enum": ["vertical", "inline-wrap", "inline-nowrap"]
    },
    "distractor-order": {
      "type": "string",
      "enum": ["random", "inherit"]
    },
    "feedback": {
      "type": "string",
      "enum": ["none", "first-wrong", "first-wrong-verbose"]
    },
    "file-name": {
      "type": "string"
    },
    "format": {
      "type": "string",
      "enum": ["default", "code"]
    },
    "grading-method": {
      "type": "string",
      "enum": ["unordered", "ordered", "ranking", "dag", "external"]
    },
    "indentation": {
      "type": "string",
      "format": "boolean"
    },
    "inline": {
      "type": "string",
      "format": "boolean",
      "deprecated": true,
      "description": "Use the \"display-blocks\" attribute instead."
    },
    "max-incorrect": {
      "type": "string",
      "format": "integer"
    },
    "max-indent": {
      "type": "string",
      "format": "integer"
    },
    "min-incorrect": {
      "type": "string",
      "format": "integer"
    },
    "partial-credit": {
      "type": "string",
      "enum": ["none", "lcs"]
    },
    "solution-header": {
      "type": "string"
    },
    "solution-placement": {
      "type": "string",
      "enum": ["right", "bottom"]
    },
    "source-blocks-order": {
      "type": "string",
      "enum": ["random", "alphabetized", "ordered", "random-sections"]
    },
    "source-header": {
      "type": "string"
    },
    "weight": {
      "type": "string",
      "format": "integer"
    }
  },
  "required": ["answers-name"],
  "additionalProperties": false
}
