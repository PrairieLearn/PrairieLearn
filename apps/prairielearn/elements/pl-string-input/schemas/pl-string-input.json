{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "allow-blank": {
      "type": "string",
      "format": "boolean"
    },
    "answers-name": {
      "type": "string"
    },
    "aria-label": {
      "type": "string"
    },
    "correct-answer": {
      "type": "string"
    },
    "correct-answer-format": {
      "type": "string",
      "enum": ["exact", "regex"]
    },
    "display": {
      "type": "string",
      "enum": ["block", "inline", "embed"]
    },
    "escape-unicode": {
      "type": "string",
      "format": "boolean",
      "deprecated": true,
      "description": "This attribute is ignored; Unicode escaping is always applied when needed."
    },
    "ignore-case": {
      "type": "string",
      "format": "boolean"
    },
    "initial-value": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "multiline": {
      "type": "string",
      "format": "boolean"
    },
    "normalize-to-ascii": {
      "type": "string",
      "format": "boolean"
    },
    "placeholder": {
      "type": "string"
    },
    "remove-leading-trailing": {
      "type": "string",
      "format": "boolean"
    },
    "remove-spaces": {
      "type": "string",
      "format": "boolean"
    },
    "show-help-text": {
      "type": "string",
      "format": "boolean"
    },
    "show-score": {
      "type": "string",
      "format": "boolean"
    },
    "size": {
      "type": "string",
      "format": "integer"
    },
    "suffix": {
      "type": "string"
    },
    "weight": {
      "type": "string",
      "format": "integer"
    }
  },
  "required": ["answers-name"],
  "additionalProperties": false
}
