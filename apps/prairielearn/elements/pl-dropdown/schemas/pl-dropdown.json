{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "allow-blank": {
      "type": "string",
      "format": "boolean"
    },
    "answers-name": {
      "type": "string"
    },
    "aria-label": {
      "type": "string"
    },
    "blank": {
      "type": "string",
      "format": "boolean"
    },
    "sort": {
      "type": "string",
      "enum": ["random", "ascend", "descend", "fixed"]
    },
    "weight": {
      "type": "string",
      "format": "integer"
    }
  },
  "required": ["answers-name"],
  "additionalProperties": false
}
