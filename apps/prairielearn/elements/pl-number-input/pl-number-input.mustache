{{#question}}
{{#inline}}<span class="d-inline-block ms-2">{{/inline}}
    <span class="input-group pl-number-input">
        {{#label}}
        <span class="input-group-text" id="pl-number-input-{{uuid}}-label">{{{label}}}</span>
        {{/label}}
        <input
          id="pl-number-input-textfield-{{uuid}}"
          name="{{name}}"
          type="text"
          inputmode="text"
          autocomplete="off"
          autocorrect="off"
          class="form-control pl-number-input-input {{#parse_error}}has-validation is-invalid{{/parse_error}}"
          {{#parse_error}}aria-invalid="true"{{/parse_error}}
          size="{{size}}"
          {{^editable}}disabled{{/editable}}
          {{#raw_submitted_answer}}value="{{raw_submitted_answer}}"{{/raw_submitted_answer}}
          placeholder="{{placeholder}}"
          {{#suffix}}aria-describedby="pl-number-input-{{uuid}}-suffix"{{/suffix}}
          {{#aria_label}}aria-label="{{aria_label}}"{{/aria_label}}
          {{^aria_label}}{{#label}}aria-labelledby="pl-number-input-{{uuid}}-label"{{/label}}{{/aria_label}}
        />

        {{#suffix}}
        <span class="input-group-text" id="pl-number-input-{{uuid}}-suffix">{{suffix}}</span>
        {{/suffix}}
        {{#show_info}}
            <button type="button" class="btn btn-light border d-flex align-items-center" data-bs-toggle="popover" data-bs-html="true" title="{{popup_title}}" data-bs-content="{{info}}" data-bs-placement="auto">
            <i class="fas fa-question-circle" aria-hidden="true"></i>
            </button>
        {{/show_info}}
        {{#show_score}}
            {{#correct}}
                <span class="input-group-text">
                    <span class="badge text-bg-success"><i class="fas fa-check" aria-hidden="true"></i> 100%</span>
                </span>
            {{/correct}}
            {{#partial}}
                <span class="input-group-text">
                    <span class="badge text-bg-warning"><i class="far fa-circle" aria-hidden="true"></i> {{partial}}%</span>
                </span>
            {{/partial}}
            {{#incorrect}}
                <span class="input-group-text">
                    <span class="badge text-bg-danger"><i class="fas fa-times" aria-hidden="true"></i> 0%</span>
                </span>
            {{/incorrect}}
        {{/show_score}}
    </span>
    {{#parse_error}}
        <span class="invalid-feedback d-block">
            <span class="badge text-bg-danger">
                Invalid 
                <i class="fas fa-exclamation-triangle" aria-hidden="true"></i>
            </span>
            <a 
                class="link-primary"
                tabindex="0"
                role="button"
                data-bs-placement="auto" 
                data-bs-toggle="popover"
                data-bs-html="true"
                title="Format error"
                data-bs-content="{{parse_error}}"
            >
                More info…
            </a>
        </span>
    {{/parse_error}}
{{#inline}}</span>{{/inline}}
{{/question}}


{{#submission}}
{{#block}}<div>{{/block}}{{#inline}}<span class="d-inline-block">{{/inline}}
{{#error}}
<span>

{{#parse_error}}
    {{#label}}<span>{{{label}}}</span>{{/label}}
    {{#raw_submitted_answer}}<code class="user-output-invalid">{{raw_submitted_answer}}</code>{{/raw_submitted_answer}}
    <span class="small" style="white-space: nowrap">
        <span class="badge text-bg-danger">
            Invalid <i class="fas fa-exclamation-triangle" aria-hidden="true"></i>
        </span>
        <a
            class="link-primary"
            tabindex="0"
            role="button"
            data-bs-placement="auto"
            data-bs-toggle="popover"
            data-bs-html="true"
            title="Format error"
            data-bs-content="{{parse_error}}"
        >
           More info…
        </a>
    </span>
{{/parse_error}}
{{#missing_input}}
    <span class="small" style="white-space: nowrap">
    {{#label}}<span>{{{label}}}</span>{{/label}}
        <span class="badge text-bg-dark border">
            Missing input 
            <i class="fas fa-exclamation-triangle" aria-hidden="true"></i>
        </span>
        <a 
            class="link-primary"
            tabindex="0"
            role="button"
            data-bs-placement="auto"
            data-bs-toggle="popover"
            data-bs-html="true"
            title="Missing input"
            data-bs-content="There is no submitted value for this field.  This may have happened because the question was changed by course staff after the answer was submitted."
        >
           More info…
        </a>
    </span>
{{/missing_input}}

</span>

{{/error}}
{{^error}}

{{#label}}<span>{{{label}}}</span>{{/label}}
<samp>{{submitted_answer}}</samp>
{{#suffix}}<span>{{suffix}}</span>{{/suffix}}

{{#show_score}}
    {{#feedback}}
    <div class="d-inline-flex pl-number-input-feedback">
    {{feedback}}
    </div>
    {{/feedback}}


    {{#correct}}
    <span id="pl-number-input-correct-{{uuid}}">
        <span class="badge text-bg-success"><i class="fas fa-check" aria-hidden="true"></i> 100%</span>
    </span>
    {{/correct}}
    {{#partial}}
    <span class="badge text-bg-warning"><i class="far fa-circle" aria-hidden="true"></i> {{partial}}%</span>
    {{/partial}}
    {{#incorrect}}
    <span class="badge text-bg-danger"><i class="fas fa-times" aria-hidden="true"></i> 0%</span>
    {{/incorrect}}
{{/show_score}}

{{/error}}
{{#inline}}</span>{{/inline}}{{#block}}</div>{{/block}}
{{/submission}}

{{#answer}}
{{#block}}<div>{{/block}}{{#inline}}<span class="d-inline-block">{{/inline}}
{{#label}}<span>{{{label}}}</span>{{/label}}
<samp>{{correct_answer}}</samp>
{{#suffix}}<span>{{suffix}}</span>{{/suffix}}
{{#inline}}</span>{{/inline}}{{#block}}</div>{{/block}}
{{/answer}}


{{#format}}
{{#show_info}}
<p>
Answer with a {{#allow_complex}}real or complex {{/allow_complex}}number (e.g., <code>1.5</code>{{#allow_complex}} or <code>1+2j</code>{{/allow_complex}}).
You may also use scientific notation (e.g., <code>1.2e03</code>){{#allow_fractions}} or fractions (e.g., <code>3/2</code>){{/allow_fractions}}.
Do not write variables{{^allow_fractions}}, fractions like <code>3/2</code>,{{/allow_fractions}} or other symbols.
{{#allow_complex}}The real and imaginary parts must each{{/allow_complex}}{{^allow_complex}}The answer must{{/allow_complex}} be between <code>-1e308</code> and <code>1e308</code>.
</p>
{{#allow_complex}}
<p>Complex numbers must use either <code>i</code> or <code>j</code> as the imaginary unit, must place the imaginary unit after the imaginary part (e.g., <code>2j</code> not <code>j2</code>), must write the imaginary part even when <code>1</code> or <code>-1</code> (e.g., <code>1j</code> not <code>j</code>), and must write the real part before the imaginary part (e.g., <code>1+2j</code> not <code>2j+1</code>). Parenthesized form is also accepted (e.g., <code>(1+2j)</code>).</p>
{{/allow_complex}}
{{#relabs}}
{{#show_tolerance}}<p>Your answer must be accurate to within {{#nonzero_rtol}}{{rtol_pct}}%{{#show_atol}} plus an additional <code>{{atol}}</code>{{/show_atol}} of the correct answer{{/nonzero_rtol}}{{^nonzero_rtol}}<code>{{atol}}</code> of the correct answer{{/nonzero_rtol}}. For example, if the correct answer is <code>{{example_true}}</code>, then a submission between <code>{{example_true}} &minus; {{example_eps}}</code> and <code>{{example_true}} + {{example_eps}}</code> is graded correct.</p>{{/show_tolerance}}{{^show_tolerance}}<p>Your answer must exactly match the correct answer.</p>{{/show_tolerance}}
{{/relabs}}
{{#sigfig}}<p>Your answer must be accurate to {{digits}} significant figure{{#digits_plural}}s{{/digits_plural}}. For example, if the correct answer is <code>1.234</code>, then a submission between <code>1.234 &minus; {{comparison_eps}}</code> and <code>1.234 + {{comparison_eps}}</code> is graded correct.</p>{{/sigfig}}{{#decdig}}<p>Your answer must be accurate to {{digits}} decimal place{{#digits_plural}}s{{/digits_plural}}. For example, if the correct answer is <code>1.234</code>, then a submission between <code>1.234 &minus; {{comparison_eps}}</code> and <code>1.234 + {{comparison_eps}}</code> is graded correct.</p>{{/decdig}}
{{/show_info}}
{{/format}}

{{#shortformat}}
{{#allow_complex}}real or complex{{/allow_complex}}{{^allow_complex}}number{{/allow_complex}} {{#relabs}}{{#show_tolerance}}{{#nonzero_rtol}}{{#show_atol}}±({{rtol_pct}}% + {{atol}}){{/show_atol}}{{^show_atol}}±{{rtol_pct}}%{{/show_atol}}{{/nonzero_rtol}}{{^nonzero_rtol}}±{{atol}}{{/nonzero_rtol}}{{/show_tolerance}}{{^show_tolerance}}(exact){{/show_tolerance}}{{/relabs}}{{#sigfig}}({{digits}} sig fig{{#digits_plural}}s{{/digits_plural}}){{/sigfig}}{{#decdig}}({{digits}} decimal place{{#digits_plural}}s{{/digits_plural}}){{/decdig}}
{{/shortformat}}

{{#format_error}}
    <p>
        {{#format_error_message}}
            {{{ format_error_message }}}
        {{/format_error_message}}
        {{^format_error_message}}
            Invalid format: the submitted answer is not formatted as a {{#complex}}real or complex {{/complex}}number.
        {{/format_error_message}}
        Do not write variables{{^allow_fractions}}, fractions,{{/allow_fractions}} or other symbols.
    </p>
    <p>Example <i>valid</i> inputs: <code>5</code><code class="ms-3">-17</code><code class="ms-3">4.25e7</code>{{#complex}}<code class="ms-3">3.6i</code>{{/complex}}{{#allow_fractions}}<code class="ms-3">3/7</code>{{/allow_fractions}}</p>
    <p>Example <i>invalid</i> inputs: <code>6+9</code><code class="ms-3">4*10^7</code><code class="ms-3">3*pi</code>{{^complex}}<code class="ms-3">3.6i</code>{{/complex}}{{^allow_fractions}}<code class="ms-3">3/7</code>{{/allow_fractions}}</p>
{{/format_error}}
