{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "allow-blank": {
      "type": "string",
      "format": "boolean"
    },
    "allow-feedback": {
      "type": "string",
      "format": "boolean"
    },
    "answers-name": {
      "type": "string"
    },
    "aria-label": {
      "type": "string"
    },
    "atol": {
      "type": "string"
    },
    "blank-value": {
      "type": "string"
    },
    "comparison": {
      "type": "string",
      "enum": ["relabs", "sigfig", "exact", "decdig"]
    },
    "correct-answer": {
      "type": "string"
    },
    "custom-format": {
      "type": "string"
    },
    "digits": {
      "type": "string",
      "format": "integer"
    },
    "display": {
      "type": "string",
      "enum": ["block", "inline"]
    },
    "grading-mode": {
      "type": "string",
      "enum": ["with-units", "exact-units", "only-units"]
    },
    "initial-value": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "magnitude-partial-credit": {
      "type": "string",
      "format": "number"
    },
    "placeholder": {
      "type": "string"
    },
    "rtol": {
      "type": "string",
      "format": "number"
    },
    "show-help-text": {
      "type": "string",
      "format": "boolean"
    },
    "show-score": {
      "type": "string",
      "format": "boolean"
    },
    "size": {
      "type": "string",
      "format": "integer"
    },
    "suffix": {
      "type": "string"
    },
    "weight": {
      "type": "string",
      "format": "integer"
    }
  },
  "required": ["answers-name"],
  "additionalProperties": false
}
