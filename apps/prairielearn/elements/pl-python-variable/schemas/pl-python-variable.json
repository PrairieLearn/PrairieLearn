      "description": "Use the \"compact-sequences\" attribute instead."
    },
    "compact-sequences": {
      "type": "string",
      "format": "boolean"
    },
    "copy-code-button": {
      "type": "string",
      "format": "boolean"
    },
    "depth": {
      "type": "string",
      "format": "integer"
    },
    "indent": {
      "type": "string",
      "format": "integer"
    },
    "no-highlight": {
      "type": "string",
      "format": "boolean"
    },
    "params-name": {
      "type": "string"
    },
    "prefix": {
      "type": "string"
    },
    "prefix-newline": {
      "type": "string",
