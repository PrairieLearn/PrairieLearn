    "initial-value": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "placeholder": {
      "type": "string"
    },
    "show-help-text": {
      "type": "string",
      "format": "boolean"
    },
    "show-score": {
      "type": "string",
      "format": "boolean"
    },
    "size": {
      "type": "string",
      "format": "integer"
    },
    "suffix": {
      "type": "string"
    },
    "variables": {
      "type": "string"
    },
    "weight": {
      "type": "string",
      "format": "integer"
    }
