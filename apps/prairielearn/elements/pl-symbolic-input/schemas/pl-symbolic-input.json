  "type": "object",
  "properties": {
    "additional-simplifications": {
      "type": "string"
    },
    "allow-blank": {
      "type": "string",
      "format": "boolean"
    },
    "allow-complex": {
      "type": "string",
      "format": "boolean"
    },
    "allow-sets": {
      "type": "string",
      "format": "boolean"
    },
    "allow-trig-functions": {
      "type": "string",
      "format": "boolean"
    },
    "answers-name": {
      "type": "string"
    },
    "aria-label": {
      "type": "string"
    },
    "blank-value": {
      "type": "string"
    },
    "correct-answer": {
      "type": "string"
    },
    "custom-functions": {
      "type": "string"
    },
    "display": {
      "type": "string",
      "enum": ["block", "inline"]
    },
    "display-log-as-ln": {
      "type": "string",
      "format": "boolean"
    },
    "display-simplified-expression": {
      "type": "string",
      "format": "boolean"
    },
    "formula-editor": {
      "type": "string",
      "format": "boolean"
    },
