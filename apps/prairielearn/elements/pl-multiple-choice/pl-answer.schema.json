{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "type": "object",
  "properties": {
    "correct": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "format": "pl-boolean",
          "type": "string"
        }
      ]
    },
    "feedback": {
      "type": "string"
    },
    "score": {
      "errorMessage": "Score must be in the range [0.0, 1.0].",
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
