#!/usr/bin/env node

// usage:
// $ tsx gen-element-schemas.mts [check]
//
// Discovers element schema modules under
// `apps/prairielearn/src/lib/element-schemas/elements/*.ts` (each exporting an
// `element` of type `ElementSchemaModule`) and regenerates everything derived
// from them:
//   - the on-disk JSON schemas under `apps/prairielearn/elements/<tag>/schemas/`
//   - the static module registry `registry.generated.ts`
//   - the full on-disk linter config `.htmlmustache.jsonc`
//
// `.htmlmustache.jsonc` is generated in its entirety from the shared runtime
// config in `apps/prairielearn/src/lib/htmlMustacheConfig.ts` (the source of
// truth), with on-disk-only settings layered on (see the constants below). The
// runtime `Config` type can't express top-level or per-rule `include`/`exclude`
// — the in-memory linter has no filesystem to match against — so those live here.
//
// Run with `check` to verify the generated files are up to date instead of
// writing them.

import fs from 'node:fs';
import path from 'node:path';
import { pathToFileURL } from 'node:url';

import prettier from 'prettier';

import type { Config, CustomTag } from '@prairielearn/tree-sitter-htmlmustache/linter';

import type {
  ElementChildSchema,
  ElementSchemaModule,
} from '../apps/prairielearn/src/lib/element-schemas/types.js';

const check = process.argv[2] === 'check';

const REPO_ROOT = path.resolve(import.meta.dirname, '..');
const ELEMENTS_SRC_DIR = path.resolve(
  REPO_ROOT,
  'apps/prairielearn/src/lib/element-schemas/elements',
);
const ELEMENTS_OUTPUT_DIR = path.resolve(REPO_ROOT, 'apps/prairielearn/elements');
const REGISTRY_PATH = path.resolve(
  REPO_ROOT,
  'apps/prairielearn/src/lib/element-schemas/registry.generated.ts',
);
const HTMLMUSTACHE_CONFIG_PATH = path.resolve(REPO_ROOT, '.htmlmustache.jsonc');
const HTMLMUSTACHE_CONFIG_SRC = path.resolve(
  REPO_ROOT,
  'apps/prairielearn/src/lib/htmlMustacheConfig.ts',
);

// On-disk-only linter settings layered onto the shared `htmlMustacheConfig` when
// generating `.htmlmustache.jsonc`. The runtime `Config` type omits top-level and
// per-rule `include`/`exclude` (the in-memory API has no filesystem to match
// against), so the CLI-only file globs and plugin path live here instead.
const CONFIG_INCLUDE = [
  'apps/prairielearn/elements/**/*.mustache',
  'exampleCourse/**/question.html',
  'testCourse/**/question.html',
  'apps/prairielearn/src/tests/**/question.html',
];
const CONFIG_EXCLUDE = [
  // Uses legacy v2 EJS syntax (<% %>) which cannot be parsed as mustache.
  'testCourse/questions/addVectors/question.html',
];
const CONFIG_PLUGIN_MODULE = './apps/prairielearn/src/lib/element-schemas/htmlmustache-plugin.ts';

// Per-rule file excludes for the on-disk linter. These rules are advisory for
// course content but must not fire on the element templates themselves (which
// legitimately contain raw inputs/images), and only the CLI lints those.
const CLI_RULE_EXCLUDES: Record<string, string[]> = {
  'pl-prefer-pl-inputs': ['apps/prairielearn/elements/**/*.mustache'],
  'pl-prefer-pl-figure': ['apps/prairielearn/elements/**/*.mustache'],
};

// Custom tags that aren't PrairieLearn elements. Only the on-disk CLI lints the
// files that use them, so they're intentionally absent from `htmlMustacheConfig`.
const NON_PL_CUSTOM_TAGS: CustomTag[] = [
  { name: 'clickable-image' },
  { name: 'course-element' },
  { name: 'extendable-element' },
  { name: 'math-field', allowBooleanAttributes: true },
];

const GENERATED_CONFIG_HEADER = [
  '// AUTO-GENERATED by scripts/gen-element-schemas.mts — do not edit by hand.',
  '// The shared linter config in `apps/prairielearn/src/lib/htmlMustacheConfig.ts`',
  '// is the source of truth; this file layers on the on-disk-only settings',
  '// (include/exclude/pluginModule, non-PL tags, and per-rule excludes) defined in',
  '// the generator, and points each element `schema` at its generated JSON file.',
  '// Run `make update-element-schemas` to regenerate.',
].join('\n');

interface DiscoveredElement {
  tag: string;
  element: ElementSchemaModule;
}

function discoverModuleFiles(): string[] {
  return fs
    .readdirSync(ELEMENTS_SRC_DIR)
    .filter(
      (file) =>
        file.endsWith('.ts') && !file.endsWith('.validator.ts') && !file.endsWith('.test.ts'),
    )
    .sort();
}

async function loadElements(): Promise<DiscoveredElement[]> {
  const elements: DiscoveredElement[] = [];
  for (const file of discoverModuleFiles()) {
    const tag = file.replace(/\.ts$/, '');
    const moduleUrl = pathToFileURL(path.join(ELEMENTS_SRC_DIR, file)).href;
    const module = (await import(moduleUrl)) as { element?: ElementSchemaModule };
    if (!module.element) {
      throw new Error(`elements/${file} must export an \`element\` of type ElementSchemaModule`);
    }
    if (module.element.tag !== tag) {
      throw new Error(
        `elements/${file}: element.tag "${module.element.tag}" must match the filename "${tag}"`,
      );
    }
    elements.push({ tag, element: module.element });
  }
  const identifiers = new Map<string, string>();
  for (const { tag } of elements) {
    const identifier = toCamelCase(tag);
    const existing = identifiers.get(identifier);
    if (existing) {
      throw new Error(
        `Element tags "${existing}" and "${tag}" both map to the generated identifier "${identifier}"; rename one.`,
      );
    }
    identifiers.set(identifier, tag);
  }
  return elements.sort((a, b) => a.tag.localeCompare(b.tag));
}

/** Absolute paths of all currently-existing generated schema JSON files. */
function findExistingSchemaFiles(): string[] {
  const schemaFiles: string[] = [];
  for (const entry of fs.readdirSync(ELEMENTS_OUTPUT_DIR, { withFileTypes: true })) {
    if (!entry.isDirectory()) continue;
    const schemasDir = path.join(ELEMENTS_OUTPUT_DIR, entry.name, 'schemas');
    let schemasEntries: fs.Dirent[];
    try {
      schemasEntries = fs.readdirSync(schemasDir, { withFileTypes: true });
    } catch {
      continue;
    }
    for (const schemasEntry of schemasEntries) {
      if (schemasEntry.isFile() && schemasEntry.name.endsWith('.json')) {
        schemaFiles.push(path.join(schemasDir, schemasEntry.name));
      }
    }
  }
  return schemaFiles;
}

function toCamelCase(tag: string): string {
  return tag
    .split('-')
    .map((part, index) => (index === 0 ? part : part.charAt(0).toUpperCase() + part.slice(1)))
    .join('');
}

/** Path on disk for a generated schema file, relative to the repo root. */
function schemaRelPath(tag: string, schemaTag: string): string {
  return `apps/prairielearn/elements/${tag}/schemas/${schemaTag}.json`;
}

interface ElementSchemas {
  /** Schema contents keyed by schema file name (without `.json`). */
  files: Map<string, Record<string, unknown>>;
  /** Schema file name for each dotted child path that declares a schema. */
  fileNameByPath: Map<string, string>;
}

/**
 * All generated schema files for an element: the root schema plus one per
 * (possibly nested) child tag that declares a schema. A child whose schema is
 * identical to one already collected for the same tag (e.g. `pl-answer` under
 * `pl-block-group`) reuses that file instead of getting a `parent.child`
 * variant — the Python runtime loads schemas by tag name and would never read
 * the duplicate.
 */
function collectElementSchemas(element: ElementSchemaModule): ElementSchemas {
  const files = new Map<string, Record<string, unknown>>([[element.tag, element.schema]]);
  const fileNameByPath = new Map<string, string>();
  const visit = (children: Record<string, ElementChildSchema>, prefix: string[]) => {
    for (const [childTag, child] of Object.entries(children)) {
      const childPath = [...prefix, childTag];
      if (child.schema) {
        const dotted = childPath.join('.');
        const schemaJson = JSON.stringify(child.schema);
        const existing = [...files.keys()].find(
          (name) =>
            (name === childTag || name.endsWith(`.${childTag}`)) &&
            JSON.stringify(files.get(name)) === schemaJson,
        );
        if (!existing) files.set(dotted, child.schema);
        fileNameByPath.set(dotted, existing ?? dotted);
      }
      if (child.children) visit(child.children, childPath);
    }
  };
  if (element.children) visit(element.children, []);
  return { files, fileNameByPath };
}

/** The `./`-prefixed path used to reference a schema from `.htmlmustache.jsonc`. */
function schemaConfigPath(tag: string, schemaTag: string): string {
  return `./${schemaRelPath(tag, schemaTag)}`;
}

async function format(filePath: string, contents: string): Promise<string> {
  const config = await prettier.resolveConfig(filePath);
  return prettier.format(contents, { ...config, filepath: filePath });
}

function buildRegistry(elements: DiscoveredElement[]): string {
  const imports = elements
    .map((e) => `import { element as ${toCamelCase(e.tag)} } from './elements/${e.tag}.ts';`)
    .join('\n');
  const names = elements.map((e) => toCamelCase(e.tag)).join(', ');
  return [
    '// AUTO-GENERATED by scripts/gen-element-schemas.mts — do not edit by hand.',
    '// Run `make update-element-schemas` to regenerate after adding or removing an',
    '// element schema module under `./elements`.',
    imports,
    "import type { ElementSchemaModule } from './types.js';",
    '',
    `export const elementModules: ElementSchemaModule[] = [${names}];`,
    '',
  ].join('\n');
}

type ChildTag = NonNullable<CustomTag['children']>[number];

/**
 * Convert a runtime custom tag to its on-disk form. Element tags carry inline
 * JSON Schema objects at runtime, but `.htmlmustache.jsonc` references the
 * generated schema files by path so the CLI (and Python) can load them lazily.
 * Non-element tags are returned unchanged.
 */
function toOnDiskCustomTag(
  tag: CustomTag,
  elementByTag: Map<string, DiscoveredElement>,
): CustomTag {
  const element = elementByTag.get(tag.name);
  if (!element) return tag;
  const onDisk: CustomTag = { ...tag, schema: schemaConfigPath(tag.name, tag.name) };
  if (tag.children) {
    const { fileNameByPath } = collectElementSchemas(element.element);
    onDisk.children = toOnDiskChildTags(
      tag.name,
      tag.children,
      element.element.children ?? {},
      [],
      fileNameByPath,
    );
  }
  return onDisk;
}

function toOnDiskChildTags(
  rootTag: string,
  children: ChildTag[],
  childSchemas: Record<string, ElementChildSchema>,
  prefix: string[],
  fileNameByPath: Map<string, string>,
): ChildTag[] {
  return children.map((child) => {
    const node = childSchemas[child.name];
    if (!node) return child;
    const childPath = [...prefix, child.name];
    const onDisk: ChildTag = { ...child };
    const fileName = fileNameByPath.get(childPath.join('.'));
    if (fileName) {
      onDisk.schema = schemaConfigPath(rootTag, fileName);
    }
    if (child.children && node.children) {
      onDisk.children = toOnDiskChildTags(
        rootTag,
        child.children,
        node.children,
        childPath,
        fileNameByPath,
      );
    }
    return onDisk;
  });
}

/**
 * Build the full on-disk linter config from the shared runtime `htmlMustacheConfig`
 * plus the on-disk-only settings above. The registry must already be on disk so
 * the dynamically-imported config reflects the current element modules.
 */
async function buildHtmlMustacheConfig(elements: DiscoveredElement[]): Promise<string> {
  const { htmlMustacheConfig } = (await import(pathToFileURL(HTMLMUSTACHE_CONFIG_SRC).href)) as {
    htmlMustacheConfig: Config;
  };
  const elementByTag = new Map(elements.map((e) => [e.tag, e]));
  const config = {
    include: CONFIG_INCLUDE,
    exclude: CONFIG_EXCLUDE,
    pluginModule: CONFIG_PLUGIN_MODULE,
    ...htmlMustacheConfig,
    customRules: htmlMustacheConfig.customRules?.map((rule) =>
      rule.id in CLI_RULE_EXCLUDES ? { ...rule, exclude: CLI_RULE_EXCLUDES[rule.id] } : rule,
    ),
    customTags: [
      ...(htmlMustacheConfig.customTags ?? []).map((tag) => toOnDiskCustomTag(tag, elementByTag)),
      ...NON_PL_CUSTOM_TAGS,
    ],
  };
  return await format(
    HTMLMUSTACHE_CONFIG_PATH,
    `${GENERATED_CONFIG_HEADER}\n${JSON.stringify(config, null, 2)}\n`,
  );
}

function verifyFile(filePath: string, contents: string): void {
  let existingContents: string;
  try {
    existingContents = fs.readFileSync(filePath, 'utf8');
  } catch (error) {
    console.error(`Error reading generated file ${filePath}:`, error);
    process.exit(1);
  }
  if (existingContents !== contents) {
    console.error(`Mismatch in ${filePath} (Do you need to run \`make update-element-schemas\`?)`);
    process.exit(1);
  }
}

function writeFile(filePath: string, contents: string): void {
  fs.mkdirSync(path.dirname(filePath), { recursive: true });
  fs.writeFileSync(filePath, contents);
}

console.log(check ? 'Checking element schemas...' : 'Writing element schemas...');

const elements = await loadElements();

// Files derived purely from the element modules (schema JSON + the registry).
const baseFiles: Record<string, string> = {};
const schemaPaths = new Set<string>();
for (const { tag, element } of elements) {
  for (const [schemaTag, schema] of collectElementSchemas(element).files) {
    const filePath = path.resolve(REPO_ROOT, schemaRelPath(tag, schemaTag));
    baseFiles[filePath] = await format(filePath, `${JSON.stringify(schema, null, 2)}\n`);
    schemaPaths.add(filePath);
  }
}
baseFiles[REGISTRY_PATH] = await format(REGISTRY_PATH, buildRegistry(elements));

// Schema JSON files that exist on disk but are no longer produced — left behind
// by a renamed or removed element/child tag.
const orphanedSchemaFiles = findExistingSchemaFiles().filter((file) => !schemaPaths.has(file));

if (check) {
  // Verify the element-derived files first. Once the registry is confirmed
  // current, the dynamically-imported `htmlMustacheConfig` reflects the current
  // elements and the config comparison below is meaningful.
  for (const [filePath, contents] of Object.entries(baseFiles)) {
    verifyFile(filePath, contents);
  }
  verifyFile(HTMLMUSTACHE_CONFIG_PATH, await buildHtmlMustacheConfig(elements));
  if (orphanedSchemaFiles.length > 0) {
    console.error(
      `Orphaned generated schema files (Do you need to run \`make update-element-schemas\`?):\n${orphanedSchemaFiles
        .map((file) => `  ${file}`)
        .join('\n')}`,
    );
    process.exit(1);
  }
} else {
  // Write the registry before building the config: `buildHtmlMustacheConfig`
  // imports `htmlMustacheConfig`, which reads the element registry from disk.
  for (const [filePath, contents] of Object.entries(baseFiles)) {
    writeFile(filePath, contents);
  }
  writeFile(HTMLMUSTACHE_CONFIG_PATH, await buildHtmlMustacheConfig(elements));
  for (const filePath of orphanedSchemaFiles) {
    fs.rmSync(filePath);
    // Remove the schemas/ directory if it's now empty.
    const schemasDir = path.dirname(filePath);
    if (fs.readdirSync(schemasDir).length === 0) {
      fs.rmdirSync(schemasDir);
    }
  }
}
