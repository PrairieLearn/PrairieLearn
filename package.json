{
  "name": "prairielearn",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "capture-access-control-screenshots": "CAPTURE_SCREENSHOTS=1 pnpm --filter @prairielearn/prairielearn test:e2e src/tests/e2e/captureAccessControlScreenshots.spec.ts",
    "capture-onboarding-screenshots": "CAPTURE_SCREENSHOTS=1 pnpm --filter @prairielearn/prairielearn test:e2e captureOnboardingScreenshots",
    "dev": "pnpm --filter @prairielearn/prairielearn dev",
    "dev-bun": "pnpm --filter @prairielearn/prairielearn dev:bun",
    "dev-vite": "pnpm --filter @prairielearn/prairielearn dev:vite",
    "dev-workspace-host": "pnpm --filter @prairielearn/workspace-host dev",
    "grader-host-dev": "pnpm --filter @prairielearn/grader-host dev",
    "grader-host-start": "pnpm --filter @prairielearn/grader-host start",
    "migrate": "pnpm --filter @prairielearn/prairielearn start --migrate-and-exit",
    "migrate-dev": "pnpm --filter @prairielearn/prairielearn dev:no-watch --migrate-and-exit",
    "refresh-workspace-hosts": "pnpm --filter @prairielearn/prairielearn start --refresh-workspace-hosts-and-exit",
    "refresh-workspace-hosts-dev": "pnpm --filter @prairielearn/prairielearn dev:no-watch --refresh-workspace-hosts-and-exit",
    "release": "turbo run build && node scripts/fix-workspace-versions-before-publish.mjs && changeset publish --no-git-tag",
    "start": "pnpm --filter @prairielearn/prairielearn start",
    "start-workspace-host": "pnpm --filter @prairielearn/workspace-host start",
    "test": "vitest run --coverage",
    "version": "changeset version && pnpm install --no-frozen-lockfile"
  },
  "dependencies": {
    "async": "^3.2.6",
    "node-gyp": "^12.3.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@html-eslint/eslint-plugin": "^0.60.0",
    "@html-eslint/parser": "^0.60.0",
    "@playwright/test": "^1.60.0",
    "@postgres-language-server/cli": "^0.24.0",
    "@prairielearn/eslint-config": "workspace:^",
    "@prairielearn/signed-token": "workspace:^",
    "@prairielearn/tsconfig": "workspace:^",
    "@reteps/tree-sitter-htmlmustache": "^1.3.3",
    "@typescript/native-preview": "beta",
    "@vitest/coverage-v8": "^4.1.5",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^10.3.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.4",
    "globals": "^17.6.0",
    "globby": "^16.2.0",
    "htmlhint": "^1.9.2",
    "ignore": "^7.0.5",
    "knip": "^6.11.0",
    "linkinator": "^7.6.1",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3",
    "prettier-plugin-pkg": "^0.22.1",
    "prettier-plugin-sh": "^0.18.1",
    "prettier-plugin-sql": "^0.20.0",
    "prettier-plugin-toml": "^2.0.6",
    "pyright": "^1.1.409",
    "s3rver": "^3.7.1",
    "turbo": "^2.9.14",
    "vitest": "^4.1.5",
    "zod": "^3.25.76 <4",
    "zod-to-json-schema": "^3.25.2"
  },
  "pnpm": {
    "overrides": {
      "@sa11y/common>axe-core": "^4",
      "@sa11y/format>axe-core": "^4",
      "@typescript/native-preview": "beta",
      "linkinator>marked": "^18",
      "markdownlint-cli2>smol-toml": "^1",
      "notebookjs>jsdom": "*",
      "typescript-cp>tar": "*"
    },
    "onlyBuiltDependencies": [
      "@datadog/pprof",
      "@prairielearn/bind-mount",
      "@reteps/tree-sitter-htmlmustache",
      "core-js",
      "cpu-features",
      "dtrace-provider",
      "esbuild",
      "protobufjs",
      "sharp",
      "ssh2",
      "unrs-resolver"
    ]
  }
}
