# Picking a submission element by what the student is submitting.

what: "What is the student submitting?" {
  shape: diamond
}

selection: "Selection"
numeric: "Numeric input"
text: "Text & symbolic input"
drawing: "Drawings & images"
code: "Code & files"

what -> selection: "Pick or arrange\nfrom a fixed set"
what -> numeric: "A number, vector,\nor matrix"
what -> text: "Free text, essay,\nor math expression"
what -> drawing: "Drawing, photo,\nor scan"
what -> code: "Code or uploaded file"
